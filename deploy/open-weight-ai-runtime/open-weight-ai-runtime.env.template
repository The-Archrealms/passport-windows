# Archrealms Passport open-weight AI runtime env template
# Populate in a secure deployment environment. Do not commit populated env files.

# Runtime engine: vllm or tgi. The compose file chooses the engine.
ARCHREALMS_PASSPORT_AI_RUNTIME_PROVIDER=vllm

# Runtime image. Pin to an approved immutable image digest, or to an approved
# non-latest image tag when a digest is unavailable.
ARCHREALMS_PASSPORT_AI_RUNTIME_IMAGE=<approved runtime image digest or pinned tag>

# Local validation port. Production should place the runtime behind private TLS.
ARCHREALMS_PASSPORT_AI_RUNTIME_HOST_PORT=8000
ARCHREALMS_PASSPORT_AI_RUNTIME_GPU_COUNT=1
ARCHREALMS_PASSPORT_AI_RUNTIME_LOG_LEVEL=INFO

# Hosted gateway inference target. Production readiness requires HTTPS.
ARCHREALMS_PASSPORT_AI_INFERENCE_BASE_URL=https://model-runtime.internal/v1
ARCHREALMS_PASSPORT_AI_INFERENCE_API_KEY=

# Approved model and evidence.
ARCHREALMS_PASSPORT_AI_MODEL_ID=Qwen/Qwen3-8B
ARCHREALMS_PASSPORT_AI_MODEL_ARTIFACT_SHA256=<approved model artifact sha256>
ARCHREALMS_PASSPORT_AI_MODEL_LICENSE_APPROVAL_ID=<model license approval id>

# Retrieval and knowledge approval evidence used by the hosted gateway.
ARCHREALMS_PASSPORT_AI_VECTOR_STORE_PROVIDER=<managed vector store provider>
ARCHREALMS_PASSPORT_AI_VECTOR_STORE_ID=<managed vector store id>
ARCHREALMS_PASSPORT_AI_KNOWLEDGE_APPROVAL_ROOT=<knowledge approval root>

# Optional gateway inference controls.
ARCHREALMS_PASSPORT_AI_MAX_OUTPUT_TOKENS=1024
ARCHREALMS_PASSPORT_AI_TEMPERATURE=0.2
ARCHREALMS_PASSPORT_AI_SYSTEM_PROMPT=

# Optional Hugging Face token for gated model downloads. Store only in secret storage.
HF_TOKEN=
