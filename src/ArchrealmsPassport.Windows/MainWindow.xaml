<Window x:Class="ArchrealmsPassport.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Archrealms Passport"
        Icon="Assets/AppIcon.ico"
        Height="640"
        Width="900"
        MinHeight="560"
        MinWidth="760"
        AutomationProperties.AutomationId="ArchrealmsPassportMainWindow"
        Background="#F3F1EA">
    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,0,18" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D8D2C6" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1F2F2A" />
        </Style>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,12,0,5" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#45524D" />
        </Style>
        <Style x:Key="CaptionStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5D6763" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="StatusLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#51645E" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
        <Style x:Key="StatusValueStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#1D2C27" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Background" Value="#FBFAF7" />
            <Setter Property="BorderBrush" Value="#C9C2B6" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="CodeTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource InputTextBoxStyle}">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Background" Value="#315C4B" />
            <Setter Property="BorderBrush" Value="#254438" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Foreground" Value="#20302A" />
            <Setter Property="Background" Value="#E7ECE8" />
            <Setter Property="BorderBrush" Value="#B9C6BE" />
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top"
                Background="#233B32"
                BorderBrush="#17271F"
                BorderThickness="0,0,0,1"
                Padding="24,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Width="58"
                        Height="58"
                        Background="#FFFFFF"
                        CornerRadius="8"
                        BorderBrush="#C9D3CD"
                        BorderThickness="1"
                        Padding="8">
                    <Image Source="Assets/OrderEmblem.png" Stretch="Uniform" />
                </Border>

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe UI"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="#FFFFFF"
                               Text="Archrealms Passport" />
                    <TextBlock Margin="0,4,0,0"
                               FontSize="13"
                               Foreground="#C9D9D2"
                               Text="Create, register, and keep your Passport online." />
                </StackPanel>

            </Grid>
        </Border>

        <TabControl AutomationProperties.AutomationId="MainNavigationTabs"
                    Margin="24"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0">
            <TabItem Header="Home">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="0,18,0,0">
                        <Border MaxWidth="720"
                                HorizontalAlignment="Left"
                                Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Home" />

                                <Grid Margin="0,18,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Style="{StaticResource StatusLabelStyle}" Text="Passport" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" AutomationProperties.AutomationId="HomePassportStatusText" Style="{StaticResource StatusValueStyle}" Text="{Binding PassportSummaryText}" />

                                    <TextBlock Grid.Row="2" Style="{StaticResource StatusLabelStyle}" Text="Storage" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" AutomationProperties.AutomationId="HomeStorageStatusText" Style="{StaticResource StatusValueStyle}" Text="{Binding StorageSummaryText}" />

                                    <TextBlock Grid.Row="4" Style="{StaticResource StatusLabelStyle}" Text="Storage Service" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" AutomationProperties.AutomationId="HomeNodeStatusText" Style="{StaticResource StatusValueStyle}" Text="{Binding LocalNodeSummaryText}" />

                                    <TextBlock Grid.Row="6" Style="{StaticResource StatusLabelStyle}" Text="Registration" />
                                    <TextBlock Grid.Row="6" Grid.Column="1" AutomationProperties.AutomationId="HomeRegistryStatusText" Style="{StaticResource StatusValueStyle}" Text="{Binding RegistryPackageSummaryText}" />

                                    <TextBlock Grid.Row="8" Style="{StaticResource StatusLabelStyle}" Text="Release Lane" />
                                    <TextBlock Grid.Row="8" Grid.Column="1" AutomationProperties.AutomationId="HomeReleaseLaneStatusText" Style="{StaticResource StatusValueStyle}" Text="{Binding ReleaseLaneSummaryText}" />
                                </Grid>

                                <StackPanel Visibility="{Binding HomePassportNameInputVisibility}">
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Passport Name (optional)" />
                                    <TextBox AutomationProperties.AutomationId="DisplayNameTextBox"
                                             Style="{StaticResource InputTextBoxStyle}"
                                             Text="{Binding CitizenName, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <Button AutomationProperties.AutomationId="PrimaryActionButton"
                                        Margin="0,22,0,12"
                                        HorizontalAlignment="Stretch"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding PrimaryActionCommand}"
                                        Content="{Binding PrimaryActionLabel}"
                                        Visibility="{Binding PrimaryActionVisibility}" />
                            </StackPanel>
                        </Border>

                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="AI">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="0,18,0,0">
                        <Border MaxWidth="720"
                                HorizontalAlignment="Left"
                                Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="AI" />

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Gateway URL" />
                                <TextBox AutomationProperties.AutomationId="AiGatewayUrlTextBox"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         Text="{Binding AiGatewayUrl, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Knowledge Pack" />
                                <TextBox AutomationProperties.AutomationId="AiKnowledgePackTextBox"
                                         Style="{StaticResource CodeTextBoxStyle}"
                                         Text="{Binding AiKnowledgePackId, UpdateSourceTrigger=PropertyChanged}" />

                                <CheckBox Margin="0,16,0,0"
                                          FontSize="13"
                                          Foreground="#34413C"
                                          IsChecked="{Binding AiDiagnosticsUploadOptIn}"
                                          Content="Share diagnostics" />

                                <WrapPanel Margin="0,16,0,0">
                                    <Button AutomationProperties.AutomationId="CreateAiSessionButton"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Command="{Binding CreateAiSessionCommand}"
                                            Content="Connect AI" />
                                </WrapPanel>

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Status" />
                                <TextBlock AutomationProperties.AutomationId="AiSessionStatusText"
                                           Style="{StaticResource StatusValueStyle}"
                                           Text="{Binding AiSessionStatusText}" />

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Quota" />
                                <TextBlock AutomationProperties.AutomationId="AiQuotaSummaryText"
                                           Style="{StaticResource StatusValueStyle}"
                                           Text="{Binding AiQuotaSummaryText}" />

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Session Request" />
                                <TextBox Style="{StaticResource CodeTextBoxStyle}"
                                         IsReadOnly="True"
                                         Text="{Binding LatestAiSessionRequestText, Mode=OneWay}" />

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Session Record" />
                                <TextBox Style="{StaticResource CodeTextBoxStyle}"
                                         IsReadOnly="True"
                                         Text="{Binding LatestAiSessionRecordText, Mode=OneWay}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Profile">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="0,18,0,0">
                        <Border MaxWidth="720"
                                HorizontalAlignment="Left"
                                Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Passport" />

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Passport Name (optional)" />
                                <TextBox Style="{StaticResource InputTextBoxStyle}" Text="{Binding CitizenName, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Setup" />
                                <ComboBox AutomationProperties.AutomationId="ProvisioningModeComboBox"
                                          Padding="8,5"
                                          ItemsSource="{Binding ProvisioningModes}"
                                          SelectedItem="{Binding SelectedProvisioningMode, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Existing Passport ID" />
                                <TextBox Style="{StaticResource CodeTextBoxStyle}" IsEnabled="{Binding IsJoiningExistingIdentity}" Text="{Binding ExistingIdentityId, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Device Name" />
                                <TextBox Style="{StaticResource InputTextBoxStyle}" Text="{Binding DeviceLabel, UpdateSourceTrigger=PropertyChanged}" />

                                <CheckBox Margin="0,16,0,0" FontSize="13" Foreground="#34413C" IsChecked="{Binding PreferWindowsHelloCredentials}" Content="Use Windows Hello" />

                                <WrapPanel Margin="0,18,0,0">
                                    <Button AutomationProperties.AutomationId="CreateNewIdentityButton" Style="{StaticResource ActionButtonStyle}" Command="{Binding ProvisionIdentityCommand}" Content="{Binding ProvisioningButtonLabel}" />
                                    <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ApproveJoinRequestCommand}" Content="Approve Device" />
                                    <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ImportJoinApprovalCommand}" Content="Add Device" />
                                </WrapPanel>

                                <TextBlock Margin="0,22,0,0" Style="{StaticResource SectionTitleStyle}" Text="Wallet" />

                                <Grid Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Style="{StaticResource StatusLabelStyle}" Text="Wallet Key" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" AutomationProperties.AutomationId="WalletStatusText" Style="{StaticResource StatusValueStyle}" Text="{Binding WalletSummaryText}" />

                                    <TextBlock Grid.Row="2" Style="{StaticResource StatusLabelStyle}" Text="ARCH / CC" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" AutomationProperties.AutomationId="MonetaryLedgerStatusText" Style="{StaticResource StatusValueStyle}" Text="{Binding MonetaryLedgerSummaryText}" />

                                    <TextBlock Grid.Row="4" Style="{StaticResource StatusLabelStyle}" Text="Export" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource StatusValueStyle}" Text="{Binding MonetaryExportText}" />
                                </Grid>

                                <WrapPanel Margin="0,18,0,0">
                                    <Button AutomationProperties.AutomationId="BindWalletKeyButton" Style="{StaticResource ActionButtonStyle}" Command="{Binding BindWalletKeyCommand}" Content="Bind Wallet Key" />
                                    <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding RefreshMonetaryLedgerCommand}" Content="Refresh Ledger" />
                                    <Button AutomationProperties.AutomationId="ExportMonetaryLedgerButton" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ExportMonetaryLedgerCommand}" Content="Export Account" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Recovery">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="0,18,0,0">
                        <Border MaxWidth="720"
                                HorizontalAlignment="Left"
                                Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Recovery" />

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Reason Code" />
                                <TextBox AutomationProperties.AutomationId="RecoveryReasonCodeTextBox"
                                         Style="{StaticResource CodeTextBoxStyle}"
                                         Text="{Binding RecoveryReasonCode, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Target Device ID" />
                                <TextBox AutomationProperties.AutomationId="RecoveryTargetDeviceTextBox"
                                         Style="{StaticResource CodeTextBoxStyle}"
                                         Text="{Binding RecoveryTargetDeviceId, UpdateSourceTrigger=PropertyChanged}" />

                                <WrapPanel Margin="0,16,0,0">
                                    <CheckBox Margin="0,0,18,8" FontSize="13" Foreground="#34413C" IsChecked="{Binding RecoveryFreezeWalletOperations}" Content="Freeze wallet" />
                                    <CheckBox Margin="0,0,18,8" FontSize="13" Foreground="#34413C" IsChecked="{Binding RecoveryFreezePendingEscrow}" Content="Freeze escrow" />
                                    <CheckBox Margin="0,0,18,8" FontSize="13" Foreground="#34413C" IsChecked="{Binding RecoveryRevokeAiSessions}" Content="Revoke AI" />
                                    <CheckBox Margin="0,0,18,8" FontSize="13" Foreground="#34413C" IsChecked="{Binding RecoveryPauseStorageNodeOperations}" Content="Pause storage" />
                                </WrapPanel>

                                <WrapPanel Margin="0,16,0,0">
                                    <Button AutomationProperties.AutomationId="ExportRecoveryGuidanceButton" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ExportRecoveryGuidanceCommand}" Content="Export Guidance" />
                                    <Button AutomationProperties.AutomationId="FreezeAccountButton" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding FreezeAccountCommand}" Content="Freeze Account" />
                                    <Button AutomationProperties.AutomationId="DeauthorizeDeviceButton" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding DeauthorizeDeviceCommand}" Content="Deauthorize Device" />
                                    <Button AutomationProperties.AutomationId="RevokeWalletKeyButton" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding RevokeWalletKeyCommand}" Content="Revoke Wallet" />
                                    <Button AutomationProperties.AutomationId="RotateWalletKeyButton" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding RotateWalletKeyCommand}" Content="Rotate Wallet" />
                                </WrapPanel>

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Status" />
                                <TextBlock AutomationProperties.AutomationId="RecoveryStatusText"
                                           Style="{StaticResource StatusValueStyle}"
                                           Text="{Binding RecoveryStatusText}" />

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Guidance Export" />
                                <TextBox Style="{StaticResource CodeTextBoxStyle}" IsReadOnly="True" Text="{Binding LatestRecoveryGuidanceText, Mode=OneWay}" />

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Security Freeze" />
                                <TextBox Style="{StaticResource CodeTextBoxStyle}" IsReadOnly="True" Text="{Binding LatestSecurityFreezeText, Mode=OneWay}" />

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Device Deauthorization" />
                                <TextBox Style="{StaticResource CodeTextBoxStyle}" IsReadOnly="True" Text="{Binding LatestDeviceDeauthorizationText, Mode=OneWay}" />

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Wallet Revocation" />
                                <TextBox Style="{StaticResource CodeTextBoxStyle}" IsReadOnly="True" Text="{Binding LatestWalletRevocationText, Mode=OneWay}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Admin">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="0,18,0,0">
                        <Border MaxWidth="760"
                                HorizontalAlignment="Left"
                                Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Admin Authority" />

                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="Action Type" />
                                    <ComboBox Grid.Row="1"
                                              Grid.Column="0"
                                              Margin="0,0,8,0"
                                              Height="36"
                                              ItemsSource="{Binding AdminActionTypes}"
                                              SelectedItem="{Binding AdminActionType, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource FieldLabelStyle}" Text="Authority Scope" />
                                    <TextBox Grid.Row="1"
                                             Grid.Column="1"
                                             Margin="8,0,0,0"
                                             Style="{StaticResource CodeTextBoxStyle}"
                                             Text="{Binding AdminAuthorityScope, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="Reason Code" />
                                    <TextBox Grid.Row="3"
                                             Grid.Column="0"
                                             Margin="0,0,8,0"
                                             Style="{StaticResource CodeTextBoxStyle}"
                                             Text="{Binding AdminReasonCode, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource FieldLabelStyle}" Text="Approver Device ID" />
                                    <TextBox Grid.Row="3"
                                             Grid.Column="1"
                                             Margin="8,0,0,0"
                                             Style="{StaticResource CodeTextBoxStyle}"
                                             Text="{Binding AdminApproverDeviceId, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Grid.Row="4" Grid.ColumnSpan="2" Style="{StaticResource FieldLabelStyle}" Text="Approver Device Key Path" />
                                    <TextBox Grid.Row="5"
                                             Grid.ColumnSpan="2"
                                             Style="{StaticResource CodeTextBoxStyle}"
                                             Text="{Binding AdminApproverDeviceKeyPath, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Target Record ID" />
                                <TextBox Style="{StaticResource CodeTextBoxStyle}" Text="{Binding AdminTargetRecordId, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Target Record Path" />
                                <TextBox Style="{StaticResource CodeTextBoxStyle}" Text="{Binding AdminTargetRecordPath, UpdateSourceTrigger=PropertyChanged}" />

                                <WrapPanel Margin="0,12,0,0">
                                    <Button AutomationProperties.AutomationId="HashAdminTargetRecordButton" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding HashAdminTargetRecordCommand}" Content="Hash Target" />
                                </WrapPanel>

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Target Record SHA-256" />
                                <TextBox Style="{StaticResource CodeTextBoxStyle}" Text="{Binding AdminTargetRecordSha256, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Requested Payload SHA-256" />
                                <TextBox Style="{StaticResource CodeTextBoxStyle}" Text="{Binding AdminRequestedPayloadSha256, UpdateSourceTrigger=PropertyChanged}" />

                                <WrapPanel Margin="0,16,0,0">
                                    <Button AutomationProperties.AutomationId="CreateAdminAuthorityButton" Style="{StaticResource ActionButtonStyle}" Command="{Binding CreateAdminAuthorityCommand}" Content="Create Authority" />
                                </WrapPanel>

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Status" />
                                <TextBlock AutomationProperties.AutomationId="AdminAuthorityStatusText"
                                           Style="{StaticResource StatusValueStyle}"
                                           Text="{Binding AdminAuthorityStatusText}" />

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Authority Record" />
                                <TextBox Style="{StaticResource CodeTextBoxStyle}" IsReadOnly="True" Text="{Binding LatestAdminAuthorityRecordText, Mode=OneWay}" />

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Requester Signature" />
                                <TextBox Style="{StaticResource CodeTextBoxStyle}" IsReadOnly="True" Text="{Binding LatestAdminRequesterSignatureText, Mode=OneWay}" />

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Approver Signature" />
                                <TextBox Style="{StaticResource CodeTextBoxStyle}" IsReadOnly="True" Text="{Binding LatestAdminApproverSignatureText, Mode=OneWay}" />

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Evidence" />
                                <TextBox AutomationProperties.AutomationId="AdminAuthorityEvidenceTextBox"
                                         Height="110"
                                         Style="{StaticResource CodeTextBoxStyle}"
                                         IsReadOnly="True"
                                         Text="{Binding LatestAdminAuthorityEvidenceText, Mode=OneWay}"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Storage">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="0,18,0,0">
                        <Border MaxWidth="720"
                                HorizontalAlignment="Left"
                                Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Storage" />

                                <CheckBox Margin="0,16,0,0" FontSize="13" Foreground="#34413C" IsChecked="{Binding ParticipateInPublicRegistry}" Content="Contribute storage" />

                                <Grid Margin="0,18,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="90" />
                                    </Grid.ColumnDefinitions>
                                    <Slider AutomationProperties.AutomationId="StorageAllocationSlider"
                                            Minimum="1"
                                            Maximum="500"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            Value="{Binding StorageAllocationGb, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Column="1"
                                               Margin="14,0,0,0"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               FontFamily="Consolas"
                                               FontSize="14"
                                               Foreground="#26332E"
                                               Text="{Binding StorageAllocationLabel}" />
                                </Grid>

                                <CheckBox Margin="0,16,0,0" FontSize="13" Foreground="#34413C" IsChecked="{Binding PreferWifiOnly}" Content="Use storage only on unmetered networks" />

                                <WrapPanel Margin="0,18,0,0">
                                    <Button AutomationProperties.AutomationId="InitializeNodeButton" Style="{StaticResource ActionButtonStyle}" Command="{Binding InitializeNodeCommand}" Content="Enable Storage" />
                                    <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding StopNodeCommand}" Content="Pause Storage" />
                                </WrapPanel>

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Status" />
                                <TextBlock AutomationProperties.AutomationId="StorageActionStatusText"
                                           Style="{StaticResource StatusValueStyle}"
                                           Text="{Binding StorageActionStatusText}" />

                                <TextBlock Margin="0,24,0,0" Style="{StaticResource SectionTitleStyle}" Text="Storage Redemption" />

                                <Grid Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="GB" />
                                    <TextBox Grid.Row="1" Grid.Column="0" Margin="0,0,8,0" Style="{StaticResource CodeTextBoxStyle}" Text="{Binding StorageRedemptionGb, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource FieldLabelStyle}" Text="Epochs" />
                                    <TextBox Grid.Row="1" Grid.Column="1" Margin="8,0,0,0" Style="{StaticResource CodeTextBoxStyle}" Text="{Binding StorageRedemptionEpochCount, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="CC Rate" />
                                    <TextBox Grid.Row="3" Grid.Column="0" Margin="0,0,8,0" Style="{StaticResource CodeTextBoxStyle}" Text="{Binding StorageRedemptionCcPerGbEpoch, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource FieldLabelStyle}" Text="Service Class" />
                                    <TextBox Grid.Row="3" Grid.Column="1" Margin="8,0,0,0" Style="{StaticResource CodeTextBoxStyle}" Text="{Binding StorageRedemptionServiceClass, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <WrapPanel Margin="0,16,0,0">
                                    <Button AutomationProperties.AutomationId="CreateStorageRedemptionQuoteButton" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding CreateStorageRedemptionQuoteCommand}" Content="Create Quote" />
                                    <Button AutomationProperties.AutomationId="AcceptStorageRedemptionQuoteButton" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding AcceptStorageRedemptionQuoteCommand}" Content="Accept Quote" />
                                </WrapPanel>

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Quote" />
                                <TextBox Style="{StaticResource CodeTextBoxStyle}" IsReadOnly="True" Text="{Binding LatestStorageRedemptionQuoteText, Mode=OneWay}" />

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Accepted Redemption" />
                                <TextBox Style="{StaticResource CodeTextBoxStyle}" IsReadOnly="True" Text="{Binding LatestStorageRedemptionAcceptedText, Mode=OneWay}" />

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Proof Record Path" />
                                <TextBox AutomationProperties.AutomationId="StorageRedemptionProofRecordPathTextBox" Style="{StaticResource CodeTextBoxStyle}" Text="{Binding StorageRedemptionProofRecordPath, UpdateSourceTrigger=PropertyChanged}" />

                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="Burn CC" />
                                    <TextBox Grid.Row="1" Grid.Column="0" Margin="0,0,8,0" Style="{StaticResource CodeTextBoxStyle}" Text="{Binding StorageRedemptionBurnCc, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource FieldLabelStyle}" Text="Verified GB-Days" />
                                    <TextBox Grid.Row="1" Grid.Column="1" Margin="8,0,8,0" Style="{StaticResource CodeTextBoxStyle}" Text="{Binding StorageRedemptionVerifiedGbDays, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource FieldLabelStyle}" Text="Refund CC" />
                                    <TextBox Grid.Row="1" Grid.Column="2" Margin="8,0,0,0" Style="{StaticResource CodeTextBoxStyle}" Text="{Binding StorageRedemptionRefundCc, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <WrapPanel Margin="0,16,0,0">
                                    <Button AutomationProperties.AutomationId="BurnStorageRedemptionEpochButton" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding BurnStorageRedemptionEpochCommand}" Content="Burn Epoch" />
                                    <Button AutomationProperties.AutomationId="RefundStorageRedemptionButton" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding RefundStorageRedemptionCommand}" Content="Refund Escrow" />
                                </WrapPanel>

                                <TextBlock Margin="0,24,0,0" Style="{StaticResource SectionTitleStyle}" Text="Failure Remedy" />

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Failure Evidence Path" />
                                <TextBox Style="{StaticResource CodeTextBoxStyle}" Text="{Binding StorageRedemptionFailureEvidencePath, UpdateSourceTrigger=PropertyChanged}" />

                                <WrapPanel Margin="0,12,0,0">
                                    <Button AutomationProperties.AutomationId="HashStorageFailureEvidenceButton" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding HashStorageFailureEvidenceCommand}" Content="Hash Evidence" />
                                </WrapPanel>

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Failure Evidence SHA-256" />
                                <TextBox Style="{StaticResource CodeTextBoxStyle}" Text="{Binding StorageRedemptionFailureEvidenceSha256, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Admin Evidence" />
                                <TextBox AutomationProperties.AutomationId="StorageRedemptionAdminEvidenceTextBox"
                                         Height="92"
                                         Style="{StaticResource CodeTextBoxStyle}"
                                         Text="{Binding StorageRedemptionAdminEvidenceText, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto" />

                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="Re-credit CC" />
                                    <TextBox Grid.Row="1" Grid.Column="0" Margin="0,0,8,0" Style="{StaticResource CodeTextBoxStyle}" Text="{Binding StorageRedemptionRecreditCc, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource FieldLabelStyle}" Text="Extension Epochs" />
                                    <TextBox Grid.Row="1" Grid.Column="1" Margin="8,0,0,0" Style="{StaticResource CodeTextBoxStyle}" Text="{Binding StorageRedemptionExtensionEpochCount, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <WrapPanel Margin="0,16,0,0">
                                    <Button AutomationProperties.AutomationId="RecreditStorageRedemptionButton" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding RecreditStorageRedemptionCommand}" Content="Re-credit" />
                                    <Button AutomationProperties.AutomationId="ExtendStorageRedemptionButton" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ExtendStorageRedemptionCommand}" Content="Extend Service" />
                                </WrapPanel>

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Redemption Status" />
                                <TextBlock AutomationProperties.AutomationId="StorageRedemptionStatusText" Style="{StaticResource StatusValueStyle}" Text="{Binding StorageRedemptionStatusText}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Registry">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="0,18,0,0">
                        <Border MaxWidth="820"
                                HorizontalAlignment="Left"
                                Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Registry" />

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Filter" />
                                <TextBox AutomationProperties.AutomationId="RegistryFilterTextBox"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         Text="{Binding RegistryFilterText, UpdateSourceTrigger=PropertyChanged}" />

                                <WrapPanel Margin="0,16,0,0">
                                    <Button AutomationProperties.AutomationId="RefreshRegistryBrowserButton" Style="{StaticResource ActionButtonStyle}" Command="{Binding RefreshRegistryBrowserCommand}" Content="Refresh Registry" />
                                </WrapPanel>

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Status" />
                                <TextBlock AutomationProperties.AutomationId="RegistryBrowserSummaryText" Style="{StaticResource StatusValueStyle}" Text="{Binding RegistryBrowserSummaryText}" />

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Records" />
                                <TextBox AutomationProperties.AutomationId="RegistryRecordListTextBox"
                                         Height="430"
                                         Style="{StaticResource CodeTextBoxStyle}"
                                         IsReadOnly="True"
                                         Text="{Binding RegistryRecordListText, Mode=OneWay}"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Activity">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="0,18,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Style="{StaticResource SectionTitleStyle}" Text="Status" />

                                <TextBlock Grid.Row="2" Style="{StaticResource StatusLabelStyle}" Text="Workspace" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource StatusValueStyle}" Text="{Binding WorkspaceStateText}" />

                                <TextBlock Grid.Row="4" Style="{StaticResource StatusLabelStyle}" Text="IPFS Runtime" />
                                <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource StatusValueStyle}" Text="{Binding ResolvedIpfsCliPathText}" />

                                <TextBlock Grid.Row="6" Style="{StaticResource StatusLabelStyle}" Text="Node" />
                                <TextBlock Grid.Row="6" Grid.Column="1" Style="{StaticResource StatusValueStyle}" Text="{Binding NodeStateText}" />

                                <TextBlock Grid.Row="8" Style="{StaticResource StatusLabelStyle}" Text="Diagnostics" />
                                <TextBlock Grid.Row="8" Grid.Column="1" Style="{StaticResource StatusValueStyle}" Text="{Binding LatestNodeDiagnosticsText}" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Activity Log" />
                                <TextBox AutomationProperties.AutomationId="ActivityLogTextBox"
                                         Height="430"
                                         Margin="0,12,0,0"
                                         Style="{StaticResource CodeTextBoxStyle}"
                                         IsReadOnly="True"
                                         Text="{Binding ActivityLog, Mode=OneWay}"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Advanced">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Workspace" />

                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Passport Workspace" />
                                    <TextBox Style="{StaticResource CodeTextBoxStyle}" Text="{Binding WorkspaceRoot, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="IPFS Repo Path" />
                                    <TextBox Style="{StaticResource CodeTextBoxStyle}" Text="{Binding IpfsRepoPath, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="IPFS Runtime Override" />
                                    <TextBox Style="{StaticResource CodeTextBoxStyle}" Text="{Binding IpfsCliPathOverride, UpdateSourceTrigger=PropertyChanged}" />

                                    <WrapPanel Margin="0,16,0,0">
                                        <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding SaveSettingsCommand}" Content="Save Settings" />
                                        <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding RefreshStatusCommand}" Content="Refresh Status" />
                                        <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding WriteNodeDiagnosticsCommand}" Content="Write Diagnostics" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Node Profile" />

                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Participation Mode" />
                                    <ComboBox Padding="8,5" ItemsSource="{Binding NodeParticipationModes}" SelectedItem="{Binding NodeParticipationMode, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Cache Policy" />
                                    <ComboBox Padding="8,5" ItemsSource="{Binding NodeCachePolicies}" SelectedItem="{Binding NodeCachePolicy, UpdateSourceTrigger=PropertyChanged}" />

                                    <CheckBox Margin="0,16,0,0" FontSize="13" Foreground="#34413C" IsChecked="{Binding PublishCarExports}" Content="Publish CAR archives" />

                                    <Grid Margin="0,18,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="125" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="12" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="12" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="12" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Style="{StaticResource StatusLabelStyle}" Text="Profile" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource StatusValueStyle}" Text="{Binding ParticipationProfileSummary}" />

                                        <TextBlock Grid.Row="2" Style="{StaticResource StatusLabelStyle}" Text="Config" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource StatusValueStyle}" Text="{Binding NodeConfigSummary}" />

                                        <TextBlock Grid.Row="4" Style="{StaticResource StatusLabelStyle}" Text="Runtime" />
                                        <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource StatusValueStyle}" Text="{Binding IpfsStateText}" />

                                        <TextBlock Grid.Row="6" Style="{StaticResource StatusLabelStyle}" Text="Node State" />
                                        <TextBlock Grid.Row="6" Grid.Column="1" Style="{StaticResource StatusValueStyle}" Text="{Binding NodeStateText}" />
                                    </Grid>

                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Capacity Snapshot" />
                                    <TextBox Style="{StaticResource CodeTextBoxStyle}" IsReadOnly="True" Text="{Binding LatestNodeCapacitySnapshotText, Mode=OneWay}" />

                                    <WrapPanel Margin="0,16,0,0">
                                        <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding StartNodeCommand}" Content="Start Node" />
                                        <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding StopNodeCommand}" Content="Stop Node" />
                                        <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding RestartNodeCommand}" Content="Restart Node" />
                                        <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding RepairNodeCommand}" Content="Repair Config" />
                                        <Button AutomationProperties.AutomationId="RecordNodeCapacitySnapshotButton" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding RecordNodeCapacitySnapshotCommand}" Content="Record Snapshot" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Storage Proofs" />

                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Assignment ID" />
                                    <TextBox Style="{StaticResource CodeTextBoxStyle}" Text="{Binding StorageAssignmentId, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Content CID" />
                                    <TextBox AutomationProperties.AutomationId="StorageAssignmentCidTextBox" Style="{StaticResource CodeTextBoxStyle}" Text="{Binding StorageAssignmentCid, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Manifest SHA-256" />
                                    <TextBox Style="{StaticResource CodeTextBoxStyle}" Text="{Binding StorageAssignmentManifestSha256, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Service Class" />
                                    <TextBox Style="{StaticResource CodeTextBoxStyle}" Text="{Binding StorageAssignmentServiceClass, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Assigned Bytes" />
                                    <TextBox Style="{StaticResource CodeTextBoxStyle}" Text="{Binding StorageAssignmentBytes, UpdateSourceTrigger=PropertyChanged}" />

                                    <WrapPanel Margin="0,16,0,0">
                                        <Button AutomationProperties.AutomationId="AcknowledgeStorageAssignmentButton" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding AcknowledgeStorageAssignmentCommand}" Content="Acknowledge Assignment" />
                                    </WrapPanel>

                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Latest Acknowledgment" />
                                    <TextBox Style="{StaticResource CodeTextBoxStyle}" IsReadOnly="True" Text="{Binding LatestStorageAssignmentAcknowledgmentText, Mode=OneWay}" />

                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Proof Source File Path" />
                                    <TextBox AutomationProperties.AutomationId="StorageProofSourceFilePathTextBox" Style="{StaticResource CodeTextBoxStyle}" Text="{Binding StorageProofSourceFilePath, UpdateSourceTrigger=PropertyChanged}" />

                                    <WrapPanel Margin="0,16,0,0">
                                        <Button AutomationProperties.AutomationId="CreateStorageEpochProofButton" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding CreateStorageEpochProofCommand}" Content="Create Epoch Proof" />
                                        <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding CreateLocalMeteringStatusCommand}" Content="Create Metering Status" />
                                        <Button AutomationProperties.AutomationId="VerifyLocalMeteringRecordsButton" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding VerifyLocalMeteringRecordsCommand}" Content="Verify Metering" />
                                    </WrapPanel>

                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Latest Epoch Proof" />
                                    <TextBox Style="{StaticResource CodeTextBoxStyle}" IsReadOnly="True" Text="{Binding LatestStorageEpochProofText, Mode=OneWay}" />

                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Metering Summary" />
                                    <TextBox Style="{StaticResource CodeTextBoxStyle}" IsReadOnly="True" Text="{Binding LocalMeteringSummaryText, Mode=OneWay}" />

                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Latest Metering Verification" />
                                    <TextBox Style="{StaticResource CodeTextBoxStyle}" IsReadOnly="True" Text="{Binding LatestLocalMeteringVerificationText, Mode=OneWay}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Passport Details" />

                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Passport ID" />
                                    <TextBox Style="{StaticResource CodeTextBoxStyle}" IsReadOnly="True" Text="{Binding ActiveIdentityId, Mode=OneWay}" />

                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="This Device ID" />
                                    <TextBox Style="{StaticResource CodeTextBoxStyle}" IsReadOnly="True" Text="{Binding ActiveDeviceId, Mode=OneWay}" />

                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Pending Device ID" />
                                    <TextBox Style="{StaticResource CodeTextBoxStyle}" IsReadOnly="True" Text="{Binding PendingDeviceId, Mode=OneWay}" />

                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Device Request Path" />
                                    <TextBox Style="{StaticResource CodeTextBoxStyle}" Text="{Binding JoinRequestPath, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Device Approval Path" />
                                    <TextBox Style="{StaticResource CodeTextBoxStyle}" Text="{Binding JoinApprovalPath, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Challenge" />
                                    <TextBox Style="{StaticResource CodeTextBoxStyle}" Text="{Binding ChallengeText, UpdateSourceTrigger=PropertyChanged}" />

                                    <WrapPanel Margin="0,14,0,0">
                                        <Button AutomationProperties.AutomationId="GenerateChallengeButton" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding GenerateChallengeCommand}" Content="Generate" />
                                        <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding SignChallengeCommand}" Content="Sign" />
                                    </WrapPanel>

                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Signature Record" />
                                    <TextBox Height="120" Style="{StaticResource CodeTextBoxStyle}" IsReadOnly="True" Text="{Binding ChallengeSignatureText, Mode=OneWay}" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Registration" />

                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Registration Package" />
                                    <TextBox Style="{StaticResource CodeTextBoxStyle}" IsReadOnly="True" Text="{Binding RegistrySubmissionText, Mode=OneWay}" />

                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Latest Submission CID" />
                                    <TextBox Style="{StaticResource CodeTextBoxStyle}" IsReadOnly="True" Text="{Binding RegistrySubmissionCidText, Mode=OneWay}" />

                                    <WrapPanel Margin="0,16,0,0">
                                        <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding CreateRegistrySubmissionCommand}" Content="Prepare Package" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Read-Only IPFS" />

                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Root CID" />
                                    <TextBox AutomationProperties.AutomationId="ReadOnlyIpfsCidTextBox" Style="{StaticResource CodeTextBoxStyle}" Text="{Binding ReadOnlyIpfsCid, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Relative File Path" />
                                    <TextBox Style="{StaticResource CodeTextBoxStyle}" Text="{Binding ReadOnlyIpfsRelativePath, UpdateSourceTrigger=PropertyChanged}" />

                                    <WrapPanel Margin="0,16,0,0">
                                        <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding PreviewReadOnlyIpfsFileCommand}" Content="Preview" />
                                        <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding FetchReadOnlyIpfsFileCommand}" Content="Fetch Copy" />
                                        <Button AutomationProperties.AutomationId="ExportCarButton" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ExportCarCommand}" Content="Export CAR" />
                                    </WrapPanel>

                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Preview" />
                                    <TextBox Height="150"
                                             Style="{StaticResource CodeTextBoxStyle}"
                                             IsReadOnly="True"
                                             Text="{Binding ReadOnlyIpfsPreviewText, Mode=OneWay}"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto" />

                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Last Read-Only Copy" />
                                    <TextBox Style="{StaticResource CodeTextBoxStyle}" IsReadOnly="True" Text="{Binding ReadOnlyIpfsFetchedPathText, Mode=OneWay}" />

                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Latest CAR Export" />
                                    <TextBox Style="{StaticResource CodeTextBoxStyle}" IsReadOnly="True" Text="{Binding LatestCarExportText, Mode=OneWay}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
