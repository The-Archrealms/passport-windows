<Window x:Class="ArchrealmsPassport.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Archrealms Passport"
        Height="860"
        Width="1380"
        MinHeight="760"
        MinWidth="1100"
        Background="#F4EEE1">
    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,0,18" />
            <Setter Property="Background" Value="#FFF9F1" />
            <Setter Property="BorderBrush" Value="#D7C6A0" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Foreground" Value="#FFF7ED" />
            <Setter Property="Background" Value="#70513B" />
            <Setter Property="BorderBrush" Value="#5D4331" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="CaptionStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6A604F" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top"
                Background="#E7DBC0"
                BorderBrush="#C9B286"
                BorderThickness="0,0,0,1"
                Padding="28,24,28,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontFamily="Palatino Linotype"
                               FontSize="34"
                               FontWeight="SemiBold"
                               Foreground="#423124"
                               Text="Archrealms Passport" />
                    <TextBlock Margin="0,8,0,0"
                               FontFamily="Palatino Linotype"
                               FontSize="15"
                               Foreground="#5C4A38"
                               TextWrapping="Wrap"
                               Text="Windows Passport for identity onboarding, registry packaging, local IPFS stewardship, and publication of public Archrealms record bundles." />
                </StackPanel>

                <Border Grid.Column="1"
                        Padding="16,10"
                        Background="#F7F1E4"
                        CornerRadius="14"
                        BorderBrush="#D0BF97"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock FontFamily="Palatino Linotype"
                                   FontSize="12"
                                   Foreground="#715B46"
                                   Text="Current State" />
                        <TextBlock Margin="0,2,0,0"
                                   FontFamily="Consolas"
                                   FontSize="13"
                                   Foreground="#3D2E23"
                                   Text="{Binding VerificationStateText}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="1.45*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock FontFamily="Palatino Linotype" FontSize="24" FontWeight="SemiBold" Foreground="#3F3025" Text="Identity and Workspace" />
                            <TextBlock Margin="0,8,0,18" Style="{StaticResource CaptionStyle}" Text="Each Passport identity may authorize many devices, but new devices now join by signed request and approval. Runtime records are written into a local workspace rather than into the source repository." />

                            <TextBlock FontFamily="Palatino Linotype" FontSize="15" Foreground="#4B392C" Text="Display Name" />
                            <TextBox Margin="0,6,0,12" Padding="10,7" Text="{Binding CitizenName, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock FontFamily="Palatino Linotype" FontSize="15" Foreground="#4B392C" Text="Provisioning Mode" />
                            <ComboBox Margin="0,6,0,12" Padding="8,5" ItemsSource="{Binding ProvisioningModes}" SelectedItem="{Binding SelectedProvisioningMode, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock FontFamily="Palatino Linotype" FontSize="15" Foreground="#4B392C" Text="Identity Mode" />
                            <ComboBox Margin="0,6,0,12" Padding="8,5" ItemsSource="{Binding IdentityModes}" SelectedItem="{Binding SelectedIdentityMode, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock FontFamily="Palatino Linotype" FontSize="15" Foreground="#4B392C" Text="Existing Identity ID" />
                            <TextBox Margin="0,6,0,12" Padding="10,7" FontFamily="Consolas" IsEnabled="{Binding IsJoiningExistingIdentity}" Text="{Binding ExistingIdentityId, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock FontFamily="Palatino Linotype" FontSize="15" Foreground="#4B392C" Text="Join Request Path" />
                            <TextBox Margin="0,6,0,12" Padding="10,7" FontFamily="Consolas" Text="{Binding JoinRequestPath, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock FontFamily="Palatino Linotype" FontSize="15" Foreground="#4B392C" Text="Join Approval Path" />
                            <TextBox Margin="0,6,0,12" Padding="10,7" FontFamily="Consolas" Text="{Binding JoinApprovalPath, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock FontFamily="Palatino Linotype" FontSize="15" Foreground="#4B392C" Text="Device Label" />
                            <TextBox Margin="0,6,0,12" Padding="10,7" Text="{Binding DeviceLabel, UpdateSourceTrigger=PropertyChanged}" />

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock FontFamily="Palatino Linotype" FontSize="15" Foreground="#4B392C" Text="Active Identity ID" />
                                    <TextBox Margin="0,6,0,0" Padding="10,7" FontFamily="Consolas" IsReadOnly="True" Text="{Binding ActiveIdentityId}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock FontFamily="Palatino Linotype" FontSize="15" Foreground="#4B392C" Text="Active Device ID" />
                                    <TextBox Margin="0,6,0,0" Padding="10,7" FontFamily="Consolas" IsReadOnly="True" Text="{Binding ActiveDeviceId}" />
                                </StackPanel>
                            </Grid>

                            <TextBlock FontFamily="Palatino Linotype" FontSize="15" Foreground="#4B392C" Text="Pending Device ID" />
                            <TextBox Margin="0,6,0,12" Padding="10,7" FontFamily="Consolas" IsReadOnly="True" Text="{Binding PendingDeviceId}" />

                            <TextBlock FontFamily="Palatino Linotype" FontSize="15" Foreground="#4B392C" Text="Passport Workspace" />
                            <TextBox Margin="0,6,0,12" Padding="10,7" FontFamily="Consolas" Text="{Binding WorkspaceRoot, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock FontFamily="Palatino Linotype" FontSize="15" Foreground="#4B392C" Text="IPFS Repo Path" />
                            <TextBox Margin="0,6,0,0" Padding="10,7" FontFamily="Consolas" Text="{Binding IpfsRepoPath, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock FontFamily="Palatino Linotype" FontSize="24" FontWeight="SemiBold" Foreground="#3F3025" Text="Archive Participation" />
                            <TextBlock Margin="0,8,0,18" Style="{StaticResource CaptionStyle}" Text="This machine can contribute storage for public Archrealms records and publish Passport registry submission bundles through a local Kubo node." />

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="84" />
                                </Grid.ColumnDefinitions>
                                <Slider Margin="0,6,18,0"
                                        Minimum="5"
                                        Maximum="500"
                                        TickFrequency="5"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding StorageAllocationGb, UpdateSourceTrigger=PropertyChanged}" />
                                <Border Grid.Column="1" Background="#F1E6D1" BorderBrush="#CFBE99" BorderThickness="1" CornerRadius="10" Padding="8,6">
                                    <TextBlock HorizontalAlignment="Center" FontFamily="Consolas" FontSize="14" Foreground="#4B392C" Text="{Binding StorageAllocationLabel}" />
                                </Border>
                            </Grid>

                            <WrapPanel>
                                <CheckBox Margin="0,0,18,10" FontSize="14" Foreground="#4B392C" IsChecked="{Binding ParticipateInPublicRegistry}" Content="Participate in the public registry" />
                                <CheckBox Margin="0,0,18,10" FontSize="14" Foreground="#4B392C" IsChecked="{Binding PublishCarExports}" Content="Emit CAR archives on publication" />
                                <CheckBox Margin="0,0,18,10" FontSize="14" Foreground="#4B392C" IsChecked="{Binding PreferWifiOnly}" Content="Prefer unmetered or Wi-Fi network use" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock FontFamily="Palatino Linotype" FontSize="24" FontWeight="SemiBold" Foreground="#3F3025" Text="Actions" />
                            <TextBlock Margin="0,8,0,18" Style="{StaticResource CaptionStyle}" Text="The Passport client provisions identities, maintains its own workspace, and now requires a signed join approval before activating a new device under an existing identity." />
                            <WrapPanel>
                                <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding ProvisionIdentityCommand}" Content="{Binding ProvisioningButtonLabel}" />
                                <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding ApproveJoinRequestCommand}" Content="Approve Join Request" />
                                <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding ImportJoinApprovalCommand}" Content="Import Join Approval" />
                                <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding SaveSettingsCommand}" Content="Save Settings" />
                                <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding RefreshStatusCommand}" Content="Refresh Status" />
                                <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding InitializeNodeCommand}" Content="Initialize Local IPFS Node" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock FontFamily="Palatino Linotype" FontSize="24" FontWeight="SemiBold" Foreground="#3F3025" Text="Passport Signing" />
                            <TextBlock Margin="0,8,0,18" Style="{StaticResource CaptionStyle}" Text="Use the active device credential to sign a challenge or prepare a portable registry submission package for the current Passport identity." />

                            <TextBlock FontFamily="Palatino Linotype" FontSize="15" Foreground="#4B392C" Text="Challenge" />
                            <TextBox Margin="0,6,0,12" Padding="10,7" FontFamily="Consolas" Text="{Binding ChallengeText, UpdateSourceTrigger=PropertyChanged}" />

                            <WrapPanel>
                                <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding GenerateChallengeCommand}" Content="Generate Challenge" />
                                <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding SignChallengeCommand}" Content="Sign Challenge" />
                                <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding CreateRegistrySubmissionCommand}" Content="Prepare Registry Submission" />
                                <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding PublishRegistrySubmissionCommand}" Content="Publish Submission To IPFS" />
                            </WrapPanel>

                            <TextBlock FontFamily="Palatino Linotype" FontSize="15" Foreground="#4B392C" Text="Challenge Signature Record" />
                            <TextBox Margin="0,6,0,12" Padding="10,7" FontFamily="Consolas" IsReadOnly="True" Text="{Binding ChallengeSignatureText}" TextWrapping="Wrap" />

                            <TextBlock FontFamily="Palatino Linotype" FontSize="15" Foreground="#4B392C" Text="Registry Submission Package" />
                            <TextBox Margin="0,6,0,12" Padding="10,7" FontFamily="Consolas" IsReadOnly="True" Text="{Binding RegistrySubmissionText}" TextWrapping="Wrap" />

                            <TextBlock FontFamily="Palatino Linotype" FontSize="15" Foreground="#4B392C" Text="Latest Submission CID" />
                            <TextBox Margin="0,6,0,0" Padding="10,7" FontFamily="Consolas" IsReadOnly="True" Text="{Binding RegistrySubmissionCidText}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock FontFamily="Palatino Linotype" FontSize="24" FontWeight="SemiBold" Foreground="#3F3025" Text="Status" />
                            <TextBlock Margin="0,8,0,18" Style="{StaticResource CaptionStyle}" Text="The Passport watches the workspace, node readiness, and the latest submission package produced from this machine." />

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock FontFamily="Palatino Linotype" FontSize="13" Foreground="#715B46" Text="Workspace" />
                                    <TextBlock Margin="0,4,0,0" FontFamily="Consolas" FontSize="13" Text="{Binding WorkspaceStateText}" TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock FontFamily="Palatino Linotype" FontSize="13" Foreground="#715B46" Text="IPFS CLI" />
                                    <TextBlock Margin="0,4,0,0" FontFamily="Consolas" FontSize="13" Text="{Binding IpfsStateText}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock FontFamily="Palatino Linotype" FontSize="13" Foreground="#715B46" Text="Local Node" />
                                    <TextBlock Margin="0,4,0,0" FontFamily="Consolas" FontSize="13" Text="{Binding NodeStateText}" TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock FontFamily="Palatino Linotype" FontSize="13" Foreground="#715B46" Text="Latest Package" />
                                    <TextBlock Margin="0,4,0,0" FontFamily="Consolas" FontSize="13" Text="{Binding VerificationStateText}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>

                            <Border Background="#EFE4CC" BorderBrush="#D3C095" BorderThickness="1" CornerRadius="14" Padding="14">
                                <StackPanel>
                                    <TextBlock FontFamily="Palatino Linotype" FontSize="14" Foreground="#715B46" Text="Latest Submission CID" />
                                    <TextBlock Margin="0,6,0,0" FontFamily="Consolas" FontSize="13" Foreground="#3D2E23" TextWrapping="Wrap" Text="{Binding RegistrySubmissionCidText}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock FontFamily="Palatino Linotype" FontSize="24" FontWeight="SemiBold" Foreground="#3F3025" Text="Activity Log" />
                            <TextBox Height="300"
                                     Margin="0,12,0,0"
                                     Padding="14"
                                     FontFamily="Consolas"
                                     FontSize="13"
                                     Background="#FBF7EF"
                                     BorderBrush="#D3C095"
                                     BorderThickness="1"
                                     IsReadOnly="True"
                                     Text="{Binding ActivityLog}"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
